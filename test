resource "aws_iam_role_policy" "ebs_csi_driver_kms" {
  count = var.ebs_csi_driver_enabled && var.ebs_csi_kms_key_arns != null ? 1 : 0
  name  = "ebs-csi-driver-kms"
  role  = aws_iam_role.ebs_csi_driver[0].id

  policy = jsonencode({
    Version = "2012-10-17"
    Statement = [
      {
        Sid    = "KMSAccess"
        Effect = "Allow"
        Action = [
          "kms:CreateGrant",
          "kms:ListGrants",
          "kms:DescribeKey",
        ]
        Resource = var.ebs_csi_kms_key_arns
        Condition = {
          Bool = {
            "kms:GrantIsForAWSResource" = "true"
          }
        }
      },
      {
        Sid    = "KMSEncryptDecrypt"
        Effect = "Allow"
        Action = [
          "kms:Encrypt",
          "kms:Decrypt",
          "kms:ReEncryptFrom",
          "kms:ReEncryptTo",
          "kms:GenerateDataKey",
          "kms:GenerateDataKeyWithoutPlaintext",
        ]
        Resource = var.ebs_csi_kms_key_arns
      }
    ]
  })
}
